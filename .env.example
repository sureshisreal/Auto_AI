# Copy to .env.<environment> (e.g. .env.qa) and fill in real values.
ENVIRONMENT=qa
BASE_URL=http://127.0.0.1:3000
API_BASE_URL=http://127.0.0.1:3000/api
ADMIN_USERNAME=admin@example.com
ADMIN_PASSWORD=changeme
STANDARD_USERNAME=user@example.com
STANDARD_PASSWORD=changeme
HEADLESS=true
PARALLEL_WORKERS=4
RETRIES=2

# Optional: pin a single browser (chromium | firefox | webkit). Leave unset to run all projects.
# BROWSER=chromium

# Optional: only needed if you adopt src/database (see src/database/DatabaseClientFactory.ts).
# DB_TYPE=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=app
# DB_USER=app
# DB_PASSWORD=changeme

# Optional: winston log level (error | warn | info | debug)
# LOG_LEVEL=info
