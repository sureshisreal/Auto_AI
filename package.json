{
  "name": "qe-automation-framework",
  "version": "1.0.0",
  "description": "Simple, reliable, scalable Playwright automation framework for Quality Engineering teams",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:smoke": "npx playwright test tests/smoke",
    "test:sanity": "npx playwright test tests/sanity",
    "test:regression": "npx playwright test tests/regression",
    "test:e2e": "npx playwright test tests/e2e",
    "test:api": "npx playwright test tests/api",
    "test:contract": "npx playwright test tests/contract-tests/api-contract.spec.ts",
    "test:headed": "npx playwright test --headed",
    "test:debug": "npx playwright test --debug",
    "test:ui": "npx playwright test --ui",
    "typecheck": "tsc --noEmit",
    "install:browsers": "npx playwright install --with-deps",
    "dev:server": "node src/core/tools/dev-server.js",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "compare": "node src/core/tools/compare.js",
    "chatmode:save": "node src/core/tools/save-chatmode-response.js",
    "mcp:server": "tsx mcp/mcp-server.ts",
    "allure:generate": "allure generate reports/allure-results --clean -o reports/allure-report",
    "allure:open": "allure open reports/allure-report",
    "allure:serve": "allure serve reports/allure-results",
    "allurereport": "npm run allure:generate && npm run allure:open",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "keywords": [
    "playwright",
    "automation",
    "qe",
    "quality-engineering",
    "testing",
    "pom",
    "page-object-model"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@faker-js/faker": "^9.9.0",
    "@pact-foundation/pact": "^17.0.1",
    "@playwright/test": "^1.61.1",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^26.1.0",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "adm-zip": "^0.6.0",
    "allure-commandline": "^2.43.0",
    "allure-js-commons": "^3.10.2",
    "allure-playwright": "^3.10.2",
    "axe-playwright": "^2.2.2",
    "csv-parse": "^7.0.1",
    "csv-stringify": "^6.8.1",
    "eslint": "^10.7.0",
    "exceljs": "^4.4.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lighthouse": "^13.4.1",
    "lint-staged": "^17.1.0",
    "pixelmatch": "^5.3.0",
    "playwright-lighthouse": "^4.0.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.9.4",
    "tsx": "^4.19.5",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.7.0",
    "dotenv": "^17.4.2",
    "winston": "^3.19.0"
  }
}
