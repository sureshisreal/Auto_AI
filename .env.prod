# Production environment - replace BASE_URL/API_BASE_URL with your real production endpoints.
# Credentials for prod should come from a secrets manager / CI secrets, not this file, in a real deployment.
ENVIRONMENT=prod
BASE_URL=https://www.example.com
API_BASE_URL=https://www.example.com/api
ADMIN_USERNAME=admin@example.com
ADMIN_PASSWORD=AdminPass123!
STANDARD_USERNAME=user@example.com
STANDARD_PASSWORD=UserPass123!
HEADLESS=true
PARALLEL_WORKERS=2
RETRIES=1
