# Staging environment - replace BASE_URL/API_BASE_URL with your real staging endpoints.
ENVIRONMENT=stage
BASE_URL=https://staging.example.com
API_BASE_URL=https://staging.example.com/api
ADMIN_USERNAME=admin@example.com
ADMIN_PASSWORD=AdminPass123!
STANDARD_USERNAME=user@example.com
STANDARD_PASSWORD=UserPass123!
HEADLESS=true
PARALLEL_WORKERS=4
RETRIES=2
