{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@src/*": ["src/*"],
      "@core/*": ["src/core/*"],
      "@pages/*": ["src/pages/*"],
      "@ui/*": ["src/core/ui/*"],
      "@base/*": ["src/core/ui/base/*"],
      "@components/*": ["src/core/ui/components/*"],
      "@locators/*": ["src/core/ui/locators/*"],
      "@api/*": ["src/core/api/*"],
      "@services/*": ["src/core/api/services/*"],
      "@database/*": ["src/core/api/database/*"],
      "@runtime/*": ["src/core/runtime/*"],
      "@fixtures/*": ["src/core/runtime/fixtures/*"],
      "@hooks/*": ["src/core/runtime/hooks/*"],
      "@listeners/*": ["src/core/runtime/listeners/*"],
      "@data/*": ["src/core/data/*"],
      "@testdata/*": ["src/core/data/testdata/*"],
      "@builders/*": ["src/core/data/builders/*"],
      "@models/*": ["src/core/data/models/*"],
      "@enums/*": ["src/core/data/enums/*"],
      "@config/*": ["src/core/config/*"],
      "@constants/*": ["src/core/config/constants/*"],
      "@logger/*": ["src/core/config/logger/*"],
      "@shared/*": ["src/core/shared/*"],
      "@interfaces/*": ["src/core/shared/interfaces/*"],
      "@exceptions/*": ["src/core/shared/exceptions/*"],
      "@helpers/*": ["src/core/shared/helpers/*"],
      "@utils/*": ["src/core/shared/utils/*"],
      "@validations/*": ["src/core/shared/validations/*"]
    }
  },
  "include": ["tests/**/*.ts", "mcp/**/*.ts", "src/**/*.ts", "playwright.config.ts"],
  "exclude": ["node_modules", "dist"]
}
